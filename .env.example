# ─────────────────────────────────────────────────────────────
# Nucleo — variáveis de ambiente
# Copie para `.env` e preencha. NUNCA versione o arquivo `.env`.
# ─────────────────────────────────────────────────────────────

# Banco de dados (Prisma).
# Padrão: SQLite local (zero-config). O caminho `file:` é resolvido relativo à
# pasta do schema (prisma/), então o arquivo vira prisma/nucleo.db.
DATABASE_URL="file:./nucleo.db"
# Para Postgres, troque o provider em prisma/schema.prisma para "postgresql" e use:
# DATABASE_URL="postgresql://user:pass@localhost:5432/nucleo?schema=public"

# ─── Autenticação (single-user) ──────────────────────────────
# Email de login do único usuário.
AUTH_EMAIL="voce@exemplo.com"
# Hash bcrypt da sua senha. Gere com: npm run hash-password -- "suaSenha"
AUTH_PASSWORD_HASH=""

# Segredo para assinar o cookie de sessão (JWT). 32+ bytes aleatórios.
# Gere com: npm run gen-keys
SESSION_SECRET=""

# ─── Cofre de credenciais ────────────────────────────────────
# Chave AES-256-GCM (base64, 32 bytes) para criptografar segredos em repouso.
# Gere com: npm run gen-keys
# ATENÇÃO: se perder esta chave, os segredos guardados ficam irrecuperáveis.
ENCRYPTION_KEY=""

# ─── Armazenamento de arquivos ───────────────────────────────
# Diretório onde os uploads são gravados (relativo à raiz do projeto).
STORAGE_DIR="storage"
# Tamanho máximo de upload em bytes (padrão 25MB).
MAX_UPLOAD_BYTES="26214400"

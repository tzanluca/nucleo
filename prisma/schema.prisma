// Nucleo — modelo de dados.
//
// Provider padrão: SQLite (self-host single-user, zero-config).
// Para Postgres: troque `provider` para "postgresql" e ajuste DATABASE_URL.
// Mantemos o schema portável de propósito: sem enums nativos e sem tipos
// específicos de banco, para que a troca de provider seja indolor.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Área de trabalho: agrupa tudo relacionado a um cliente/frente de trabalho.
model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  color       String   @default("#6366f1")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clients     Client[]
  projects    Project[]
  contacts    Contact[]
  events      Event[]
  documents   Document[]
  credentials Credential[]
}

/// Cliente (pessoa ou empresa) dentro de uma workspace.
model Client {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  company     String?
  email       String?
  phone       String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projects  Project[]
  contacts  Contact[]

  @@index([workspaceId])
}

/// Projeto: unidade central de trabalho, opcionalmente ligada a um cliente.
model Project {
  id          String    @id @default(cuid())
  workspaceId String
  clientId    String?
  name        String
  description String?
  status      String    @default("active") // ver src/lib/constants/project-status
  color       String    @default("#6366f1")
  startDate   DateTime?
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client      Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  events      Event[]
  documents   Document[]
  credentials Credential[]

  @@index([workspaceId])
  @@index([clientId])
}

/// Contato: pessoa vinculada a uma workspace (e opcionalmente a um cliente).
model Contact {
  id          String   @id @default(cuid())
  workspaceId String
  clientId    String?
  name        String
  role        String?
  email       String?
  phone       String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([clientId])
}

/// Compromisso da agenda, opcionalmente vinculado a um projeto.
model Event {
  id          String    @id @default(cuid())
  workspaceId String
  projectId   String?
  title       String
  description String?
  location    String?
  startsAt    DateTime
  endsAt      DateTime?
  allDay      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([startsAt])
}

/// Metadados de um arquivo enviado. O binário fica no filesystem (STORAGE_DIR).
model Document {
  id           String   @id @default(cuid())
  workspaceId  String
  projectId    String?
  originalName String
  storedName   String   @unique // nome no disco (uuid + extensão)
  mimeType     String
  sizeBytes    Int
  description  String?
  createdAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([projectId])
}

/// Credencial do cofre. O segredo é guardado cifrado (AES-256-GCM) em
/// `secretCiphertext`; o texto puro nunca toca o banco nem os logs.
model Credential {
  id               String   @id @default(cuid())
  workspaceId      String
  projectId        String?
  label            String
  username         String?
  secretCiphertext String
  url              String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([projectId])
}
